{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "branchConcurrentLimit": 0,
  "labels": [
    "dependencies"
  ],
  "schedule": "* 0 1-7 * 6",
  "packageRules": [
    {
      "addLabels": [
        "automerge"
      ],
      "automerge": true,
      "commitMessageExtra": null,
      "commitMessagePrefix": "ci(deps):",
      "matchCurrentVersion": "!/^0/",
      "matchFileNames": [
        ".github/**"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "recreateWhen": "always"
    },
    {
      "addLabels": [
        "automerge"
      ],
      "automerge": true,
      "commitMessageExtra": null,
      "commitMessagePrefix": "build(deps):",
      "matchCurrentVersion": "!/^0/",
      "matchPackageNames": [
        "*"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "recreateWhen": "always"
    }
  ]
}
