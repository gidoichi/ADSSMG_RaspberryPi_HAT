{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "automerge": true,
  "branchConcurrentLimit": 0,
  "commitMessagePrefix": "build(deps):",
  "labels": [
    "automerge",
    "dependencies"
  ],
  "recreateWhen": "always",
  "schedule": "* 0 1-7 * 6",
  "packageRules": [
    {
      "commitMessagePrefix": "ci(deps):",
      "matchFileNames": [
        ".github/**"
      ]
    }
  ]
}
